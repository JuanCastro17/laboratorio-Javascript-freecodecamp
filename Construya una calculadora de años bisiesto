
function isLeapYear(yearParam) {
    if ((yearParam % 4 === 0 && yearParam % 100 !== 0) || (yearParam % 400 === 0)) {
        return `${yearParam} is a leap year.`;
    } else {
        return `${yearParam} is not a leap year.`;
    }
}


let year = 2024;


let result = isLeapYear(year);


console.log(result);
